# KARE Editorial Agent — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# Anthropic API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Notion Integration Token (https://www.notion.so/my-integrations)
# → Créer une integration "KARE Agent" → copier le secret
# → Partager la base de données Notion avec cette integration
NOTION_TOKEN=secret_...

# ID de la base de données Notion (dans l'URL Notion)
NOTION_DATABASE_ID=6aeff41a9d6c4f7f94a799b2ab32b869

# Secret webhook (à définir librement, à recopier dans Make.com)
WEBHOOK_SECRET=kare-secret-2026

# Port du serveur webhook (Railway le définit automatiquement)
PORT=8080
